{
  "rewrites": [
    { "source": "/api/consulta",        "destination": "/api/consulta"        },
    { "source": "/api/consultas",       "destination": "/api/consultas"       },
    { "source": "/api/admin-consultas", "destination": "/api/admin-consultas" },
